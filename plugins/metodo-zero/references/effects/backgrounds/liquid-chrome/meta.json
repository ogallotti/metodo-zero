{
  "name": "Liquid Chrome",
  "slug": "liquid-chrome",
  "category": "backgrounds",
  "tags": ["hero", "continuous", "webgl", "shader", "cursor"],
  "dependencies": ["gl-utils"],
  "description": "GPU-rendered liquid chrome with iterative sine wave domain distortion, mouse-reactive ripple, and 3x3 supersampling",
  "params": {
    "--lc-bg": { "default": "#0a0a0f", "type": "color", "label": "Background color" },
    "--lc-base-color": { "default": "#4488ff", "type": "color", "label": "Base color" },
    "--lc-speed": { "default": "0.4", "type": "number", "label": "Speed", "min": 0.1, "max": 2, "step": 0.1 },
    "--lc-amplitude": { "default": "1.0", "type": "number", "label": "Amplitude", "min": 0.2, "max": 2, "step": 0.1 },
    "--lc-frequency-x": { "default": "3.0", "type": "number", "label": "Frequency X", "min": 1, "max": 8, "step": 0.5 },
    "--lc-frequency-y": { "default": "4.0", "type": "number", "label": "Frequency Y", "min": 1, "max": 8, "step": 0.5 }
  }
}
