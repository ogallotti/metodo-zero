{
  "name": "Dot Grid",
  "slug": "dot-grid",
  "category": "backgrounds",
  "tags": ["hero", "section", "cursor", "canvas"],
  "dependencies": [],
  "description": "Interactive dot grid with proximity glow, displacement, connection lines, and spatial grid optimization",
  "params": {
    "--dg-bg": { "default": "#0a0a1a", "type": "color", "label": "Background color" },
