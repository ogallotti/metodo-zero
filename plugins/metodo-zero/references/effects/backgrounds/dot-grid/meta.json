    "--dg-glow-color": { "default": "#6366f1", "type": "color", "label": "Glow color" },
    "--dg-dot-size": { "default": "1.5", "type": "number", "label": "Dot size", "min": 0.5, "max": 4, "step": 0.5 },
    "--dg-spacing": { "default": "30", "type": "number", "label": "Grid spacing", "min": 15, "max": 60, "step": 5 },
    "--dg-mouse-radius": { "default": "200", "type": "number", "label": "Mouse radius", "min": 50, "max": 400, "step": 25 },
    "--dg-connect-distance": { "default": "80", "type": "number", "label": "Connection distance", "min": 30, "max": 150, "step": 10 }
