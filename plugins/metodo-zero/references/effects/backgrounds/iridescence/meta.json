    "--iri-speed": { "default": "0.3", "type": "number", "label": "Speed", "min": 0.05, "max": 1, "step": 0.05 },
    "--iri-amplitude": { "default": "1.0", "type": "number", "label": "Amplitude", "min": 0.2, "max": 3, "step": 0.1 }
  }
