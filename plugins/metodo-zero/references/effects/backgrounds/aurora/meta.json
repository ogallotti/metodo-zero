{
  "name": "Aurora Borealis",
  "slug": "aurora",
  "category": "backgrounds",
  "tags": ["hero", "continuous", "webgl", "shader"],
  "dependencies": ["gl-utils"],
  "description": "GPU-rendered aurora borealis with simplex noise height fields, vertical streaks, and 3-color gradient ramp",
  "params": {
    "--aurora-color-1": { "default": "#00d4aa", "type": "color", "label": "Color stop 1" },
    "--aurora-color-2": { "default": "#7b2ff7", "type": "color", "label": "Color stop 2" },
    "--aurora-color-3": { "default": "#00b4d8", "type": "color", "label": "Color stop 3" },
    "--aurora-bg": { "default": "#0a0a1a", "type": "color", "label": "Background color" },
    "--aurora-speed": { "default": "0.4", "type": "number", "label": "Speed", "min": 0.1, "max": 2, "step": 0.05 },
    "--aurora-amplitude": { "default": "0.6", "type": "number", "label": "Amplitude", "min": 0.1, "max": 1.5, "step": 0.05 },
    "--aurora-blend": { "default": "0.5", "type": "number", "label": "Blend intensity", "min": 0, "max": 1, "step": 0.05 }
  }
}
