{
  "name": "Sparkles",
  "slug": "sparkles",
  "category": "decorative",
  "tags": ["continuous"],
  "dependencies": [],
  "description": "Twinkling sparkle particles that appear and fade across a container with randomized positions and timing.",
  "params": {
    "--sp-color": { "type": "color", "default": "#fbbf24", "label": "Sparkle Color" },
    "--sp-size-min": { "type": "range", "default": "4", "min": 2, "max": 10, "unit": "px", "label": "Min Size" },
    "--sp-size-max": { "type": "range", "default": "12", "min": 8, "max": 24, "unit": "px", "label": "Max Size" }
  },
  "jsParams": {
    "density": { "type": "range", "default": 20, "min": 5, "max": 50, "label": "Sparkle Density" },
    "speed": { "type": "range", "default": 1.5, "min": 0.5, "max": 4, "step": 0.1, "label": "Twinkle Speed (s)" }
  }
}
