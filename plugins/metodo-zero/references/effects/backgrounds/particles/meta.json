{
  "name": "Particles Constellation",
  "slug": "particles",
  "category": "backgrounds",
  "tags": ["hero", "continuous", "canvas", "cursor"],
  "dependencies": [],
  "description": "Interactive particle constellation with mouse repulsion and connecting lines",
  "params": {
    "--ptc-bg": { "default": "#0a0a1a", "type": "color", "label": "Background color" },
    "--ptc-color": { "default": "rgba(255,255,255,0.8)", "type": "color", "label": "Particle color" },
    "--ptc-line-color": { "default": "rgba(255,255,255,0.15)", "type": "color", "label": "Line color" }
  },
  "jsParams": {
    "count": { "default": 120, "type": "number", "label": "Particle count", "min": 20, "max": 300, "step": 10 },
    "maxSpeed": { "default": 0.4, "type": "number", "label": "Max speed", "min": 0.1, "max": 2, "step": 0.1 },
    "linkDistance": { "default": 150, "type": "number", "label": "Link distance", "min": 50, "max": 300, "step": 10 },
    "mouseRadius": { "default": 180, "type": "number", "label": "Mouse radius", "min": 50, "max": 400, "step": 10 },
    "mouseForce": { "default": 0.08, "type": "number", "label": "Mouse force", "min": 0.01, "max": 0.3, "step": 0.01 }
  }
}
