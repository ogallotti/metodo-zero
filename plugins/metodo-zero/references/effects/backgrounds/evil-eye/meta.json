{
  "name": "Evil Eye",
  "slug": "evil-eye",
  "category": "backgrounds",
  "tags": ["hero", "continuous", "webgl", "shader", "interactive"],
  "dependencies": ["gl-utils"],
  "description": "Concentric pulsing iris with radial fibers and a pupil that smoothly tracks the cursor",
  "params": {
    "--eye-iris-color": { "default": "#1e88e5", "type": "color", "label": "Iris color" },
    "--eye-pupil-color": { "default": "#0d0d0d", "type": "color", "label": "Pupil color" },
    "--eye-glow-color": { "default": "#2196f3", "type": "color", "label": "Glow color" },
    "--eye-ring-count": { "default": "12", "type": "number", "label": "Ring count", "min": 4, "max": 24, "step": 1 },
    "--eye-pulse-speed": { "default": "0.8", "type": "number", "label": "Pulse speed", "min": 0.1, "max": 3, "step": 0.1 },
    "--eye-bg": { "default": "#0a0a12", "type": "color", "label": "Background" }
  }
}
