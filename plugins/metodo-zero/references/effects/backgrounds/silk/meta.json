{
  "name": "Silk",
  "slug": "silk",
  "category": "backgrounds",
  "tags": ["hero", "continuous", "webgl", "shader"],
  "dependencies": ["gl-utils"],
  "description": "GPU-rendered flowing silk with layered rotated sine patterns and film grain noise",
  "params": {
    "--silk-bg": { "default": "#0a0a1a", "type": "color", "label": "Background color" },
    "--silk-color": { "default": "#6366f1", "type": "color", "label": "Silk color" },
    "--silk-speed": { "default": "0.3", "type": "number", "label": "Speed", "min": 0.05, "max": 1, "step": 0.05 },
    "--silk-scale": { "default": "1.0", "type": "number", "label": "Scale", "min": 0.3, "max": 3, "step": 0.1 },
    "--silk-rotation": { "default": "0.0", "type": "number", "label": "Rotation (radians)", "min": -3.14, "max": 3.14, "step": 0.1 },
    "--silk-noise-intensity": { "default": "0.04", "type": "number", "label": "Grain intensity", "min": 0, "max": 0.15, "step": 0.01 }
  }
}
